# TheHive Auth Proxy Credentials (TheHive 5.4)
# Copy this to .thehive_proxy.env and fill in the values.
# Do NOT commit .thehive_proxy.env to version control.

# Credentials for the proxy service to use to establish sessions
THEHIVE_USER=thehive-proxy@sentinelnetsolutions.com
THEHIVE_PASSWORD=SnNet!Hive2026$Q9

# Factory default admin credentials used by the bootstrap script to create the proxy user
# Default for TheHive 5.x is admin@thehive.local / secret
THEHIVE_ADMIN_USER=admin@thehive.local
THEHIVE_ADMIN_PASSWORD=secret

# The default organization name. TheHive 5 initializes with 'admin'.
THEHIVE_ORG=admin
