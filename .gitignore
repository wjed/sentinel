# SentinelNet — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
*.egg-info/
.eggs/
dist/
build/

# Terraform (module-level ignores live in infra/terraform/.gitignore)
*.tfstate
*.tfstate.*
.terraform/
crash.log
tfplan
tfplan-*

# CDK leftovers (project migrated to Terraform)
cdk.out/
cdk.context.json

# Node / frontend
node_modules/
frontend/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local / secrets (do not commit)
.env
.env.local
*.pem

# Nested repo (avoid "does not have a commit checked out")
sentinel/
